doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title=title
        link(rel="preconnect", href="https://fonts.googleapis.com")
        link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap", rel="stylesheet")
        style
            include styles.css
    body
        .dashboard-container
            .glass-card
                .header
                    .logo-icon 🪐
                    h1=message
                    p.subtitle Torznab RSS Feed Scrapper Proxy
                
                if(savedMessage)
                    .success-toast
                        span.toast-icon ✓
                        span.toast-text=savedMessage
                
                form(action="/", method="POST")
                    .input-group
                        label(for="name") 🔗 TamilMV Proxy URL
                        .input-wrapper
                            input#name(type="url", name="tamilmv_url", class="fields", required, value=tamilmv_url, placeholder="https://www.1tamilmv.cards")
                        .helper-row
                            a(href="https://torrents-proxy.com/tamilmv/", target="_blank", class="latest-proxy-link") ⚡ Get Latest Proxy List
                    
                    .input-group
                        label Custom Search Toggle
                        .radio-group
                            label.radio-label
                                input#custom_search_toggle(type="radio", name="custom_search_toggle", value="1", checked=customSearchOn)
                                span.radio-custom
                                span.radio-text Enabled
                            label.radio-label
                                input#custom_search_toggle_1(type="radio", name="custom_search_toggle", value="0", checked=customSearchOff)
                                span.radio-custom
                                span.radio-text Disabled
                    
                    .input-group
                        label(for="custom_search") 🔍 Custom Search Keyword
                        .input-wrapper
                            input#custom_search(type="text", name="custom_search", required, class="fields", value=custom_search_keyword, placeholder="movie")
                        .helper-row
                            a(href=tryUrl, target="_blank", class="try-link") 🚀 Try Current Query
                    
                    .search-section
                        h2 Search From Prowlarr-style Proxy
                        .input-group
                            label(for="search_query") 🎬 Movie Search
                            .input-wrapper
                                input#search_query(type="text", class="fields", placeholder="Enter movie name, e.g. Drishyam 3")
                        .helper-row
                            span.search-hint Type a movie name and click Search
                        button#search_btn.btn-submit(type="button") Search
                        button#xmlToggle.btn-secondary(type="button") Show XML Info
                        .search-feedback
                        .search-results(id="searchResults")
                        .xml-info-panel.hidden
                            .info-row
                                span.info-label Full Query:
                                span#lastQuery.info-value -
                            .info-row
                                span.info-label Request URL:
                                span#lastRequestUrl.info-value -
                            .info-row
                                span.info-label Result Length:
                                span#resultLength.info-value 0
                            .download-row
                                a#downloadXmlLink.download.hidden Download XML Response
                    
                    button.btn-submit(type="submit") Save Configuration
                    .log-section
                        h3 Logs
                        .log-panel(id="logPanel")

        script.
            const searchBtn = document.getElementById('search_btn');
            const xmlToggle = document.getElementById('xmlToggle');
            const searchInput = document.getElementById('search_query');
            const searchFeedback = document.querySelector('.search-feedback');
            const searchResults = document.getElementById('searchResults');
            const downloadXmlLink = document.getElementById('downloadXmlLink');
            const xmlInfoPanel = document.querySelector('.xml-info-panel');
            const lastQueryEl = document.getElementById('lastQuery');
            const lastRequestUrlEl = document.getElementById('lastRequestUrl');
            const resultLengthEl = document.getElementById('resultLength');
            let currentXmlUrl = null;
            let lastQuery = '';
            let lastRequestUrl = '';
            let lastResultLength = 0;

            function getTorznabAttr(item, name) {
                const attrs = item.getElementsByTagName('torznab:attr');
                for (let i = 0; i < attrs.length; i++) {
                    if (attrs[i].getAttribute('name') === name) {
                        return attrs[i].getAttribute('value');
                    }
                }
                return '';
            }

            function renderResults(xmlText) {
                searchResults.innerHTML = '';
                const parser = new DOMParser();
                const xmlDoc = parser.parseFromString(xmlText, 'application/xml');
                const items = xmlDoc.getElementsByTagName('item');

                if (!items.length) {
                    searchResults.innerHTML = '<div class="result-empty">No results found.</div>';
                    return;
                }

                const list = document.createElement('div');
                list.className = 'results-list';

                for (let i = 0; i < items.length; i++) {
                    const item = items[i];
                    const title = item.getElementsByTagName('title')[0]?.textContent || 'No title';
                    const link = item.getElementsByTagName('link')[0]?.textContent || '';
                    const magnet = getTorznabAttr(item, 'magneturl');
                    const size = getTorznabAttr(item, 'size');
                    const seeders = getTorznabAttr(item, 'seeders');
                    const leechers = getTorznabAttr(item, 'leechers');

                    const card = document.createElement('div');
                    card.className = 'result-card';
                    card.innerHTML = `
                        <h3>${title}</h3>
                        <div><strong>Size:</strong> ${size || 'Unknown'}</div>
                        <div><strong>Seeders:</strong> ${seeders || 'N/A'}</div>
                        <div><strong>Leechers:</strong> ${leechers || 'N/A'}</div>
                        <div><strong>Magnet:</strong> <a href="${magnet}">${magnet ? 'Download' : 'Missing'}</a></div>
                        <div><strong>Torrent URL:</strong> <a href="${link}" target="_blank">Open</a></div>
                    `;
                    list.appendChild(card);
                }

                searchResults.appendChild(list);
            }

            function addLog(message, type = 'info') {
                const logPanel = document.getElementById('logPanel');
                if (!logPanel) return;
                const entry = document.createElement('div');
                entry.className = `log-entry log-${type}`;
                entry.textContent = `${new Date().toLocaleTimeString()} — ${message}`;
                logPanel.appendChild(entry);
                logPanel.scrollTop = logPanel.scrollHeight;
            }

            function resetDownloadLink() {
                if (currentXmlUrl) {
                    URL.revokeObjectURL(currentXmlUrl);
                    currentXmlUrl = null;
                }
                if (downloadXmlLink) {
                    downloadXmlLink.href = '#';
                    downloadXmlLink.classList.add('hidden');
                }
            }

            function setDownloadLink(href, filename, label) {
                resetDownloadLink();
                if (!downloadXmlLink) return;
                downloadXmlLink.href = href;
                downloadXmlLink.download = filename;
                downloadXmlLink.textContent = label;
                downloadXmlLink.classList.remove('hidden');
            }

            function createDownloadLink(xmlText, query) {
                const xmlBlob = new Blob([xmlText], {type: 'application/xml'});
                currentXmlUrl = URL.createObjectURL(xmlBlob);
                const safeName = query.replace(/[^a-z0-9\-_]+/gi, '_').slice(0, 60) || 'tamilmv';
                setDownloadLink(currentXmlUrl, `tamilmv-search-${safeName}.xml`, `Download XML for "${query}"`);
            }

            function updateXmlInfo(query, requestUrl, length) {
                lastQuery = query;
                lastRequestUrl = requestUrl;
                lastResultLength = length;
                if (lastQueryEl) lastQueryEl.textContent = query || '-';
                if (lastRequestUrlEl) lastRequestUrlEl.textContent = requestUrl || '-';
                if (resultLengthEl) resultLengthEl.textContent = String(length || 0);
            }

            function toggleXmlInfoPanel() {
                if (!xmlInfoPanel) return;
                const isHidden = xmlInfoPanel.classList.toggle('hidden');
                xmlToggle.textContent = isHidden ? 'Show XML Info' : 'Hide XML Info';
            }

            async function loadLastApiInfo() {
                try {
                    const response = await fetch('/api/last');
                    if (!response.ok) throw new Error(`HTTP ${response.status}`);
                    const info = await response.json();
                    updateXmlInfo(info.fullQuery, info.requestUrl, info.responseLength);
                    if (info.status && info.status !== 200) {
                        addLog(`Last API status: ${info.status}${info.error ? ` (${info.error})` : ''}`, 'warn');
                    }
                    if (info.status === 200 && info.requestUrl) {
                        const safeName = (info.fullQuery || 'prowlarr').replace(/[^a-z0-9\-_]+/gi, '_').slice(0, 60);
                        setDownloadLink(info.requestUrl, `tamilmv-prowlarr-${safeName}.xml`, `Download latest XML for "${info.fullQuery}"`);
                    }
                } catch (error) {
                    addLog(`Failed to load last API info: ${error.message}`, 'warn');
                }
            }

            async function performSearch() {
                const rawQuery = searchInput.value;
                const query = rawQuery.trim();
                if (!query) {
                    searchFeedback.textContent = 'Please enter a movie name first.';
                    addLog('Search attempt with empty query', 'warn');
                    resetDownloadLink();
                    return;
                }
                searchFeedback.textContent = 'Searching...';
                searchResults.innerHTML = '';
                resetDownloadLink();
                addLog(`Full query: "${rawQuery}"`, 'info');
                addLog(`Request URL: /api?q=${encodeURIComponent(query)}`, 'info');

                try {
                    const response = await fetch(`/api?q=${encodeURIComponent(query)}`);
                    addLog(`Response: HTTP ${response.status}`, response.ok ? 'success' : 'error');
                    const text = await response.text();
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }
                    createDownloadLink(text, rawQuery || query);
                    const requestUrl = `/api?q=${encodeURIComponent(query)}`;
                    updateXmlInfo(rawQuery || query, requestUrl, text.length);
                    renderResults(text);
                    searchFeedback.textContent = `Showing results for "${query}"`;
                    addLog(`Result length: ${text.length} chars`, 'info');
                } catch (error) {
                    searchFeedback.textContent = `Search failed: ${error.message}`;
                    addLog(`Search failed: ${error.message}`, 'error');
                }
            }

            searchBtn.addEventListener('click', performSearch);
            if (xmlToggle) xmlToggle.addEventListener('click', toggleXmlInfoPanel);
            searchInput.addEventListener('keypress', event => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    performSearch();
                }
            });

            window.addEventListener('load', () => {
                loadLastApiInfo();
            });
